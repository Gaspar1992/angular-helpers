/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": ".",
    "paths": {
      "@angular-helpers/*": ["packages/*/src/index.ts"],
      "@angular-helpers/worker-http/transport": ["packages/worker-http/transport/src/index.ts"],
      "@angular-helpers/worker-http/serializer": ["packages/worker-http/serializer/src/index.ts"],
      "@angular-helpers/worker-http/backend": ["packages/worker-http/backend/src/index.ts"],
      "@angular-helpers/worker-http/interceptors": [
        "packages/worker-http/interceptors/src/index.ts"
      ],
      "@angular-helpers/worker-http/crypto": ["packages/worker-http/crypto/src/index.ts"],
      "@angular-helpers/security/forms": ["packages/security/forms/src/index.ts"],
      "@angular-helpers/security/signal-forms": ["packages/security/signal-forms/src/index.ts"],
      "@angular-helpers/browser-web-apis/experimental": [
        "packages/browser-web-apis/experimental/src/index.ts"
      ],
      "@angular-helpers/openlayers/core": ["packages/openlayers/core/src/index.ts"],
      "@angular-helpers/openlayers/layers": ["packages/openlayers/layers/src/index.ts"],
      "@angular-helpers/openlayers/controls": ["packages/openlayers/controls/src/index.ts"],
      "@angular-helpers/openlayers/interactions": ["packages/openlayers/interactions/src/index.ts"],
      "@angular-helpers/openlayers/overlays": ["packages/openlayers/overlays/src/index.ts"],
      "@angular-helpers/openlayers/military": ["packages/openlayers/military/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true,
    "strictStandalone": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
