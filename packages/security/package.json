{
  "name": "@angular-helpers/security",
  "version": "21.0.2",
  "description": "Angular security helpers for preventing ReDoS and other security vulnerabilities",
  "keywords": [
    "angular",
    "security",
    "regex",
    "redos",
    "prevention",
    "web-worker",
    "builder-pattern"
  ],
  "author": "Angular Helpers Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/angular-helpers/security"
  },
  "bugs": {
    "url": "https://github.com/angular-helpers/security/issues"
  },
  "homepage": "https://github.com/angular-helpers/security#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "build:prod": "ng-packagr -p ng-package.json && find ../../dist/security -name '*.map' -delete && find ../../dist/security -name '*.mjs' -exec sed -i '/^\\/\\/# sourceMappingURL=/d' {} +"
  },
  "peerDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "rxjs": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "tslib": "^2.0.0"
  },
  "ngPackage": {
    "lib": {
      "entryFile": "src/index.ts"
    },
    "dest": "../../dist/security",
    "allowedNonPeerDependencies": [
      "tslib"
    ]
  }
}
