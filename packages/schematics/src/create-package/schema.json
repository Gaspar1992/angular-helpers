{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "SchematicsCreatePackage",
  "title": "Create Package Options Schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the new package.",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "description": "The description of the new package.",
      "default": ""
    },
    "author": {
      "type": "string",
      "description": "The author of the new package.",
      "default": ""
    }
  },
  "required": ["name"]
}
