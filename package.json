{
  "name": "angular-helpers",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "start:test": "ng serve --configuration development --host 127.0.0.1 --port 4200 --ssl=false",
    "build": "ng build",
    "build:packages": "npm run build --workspaces --if-present",
    "build:package": "npm run build --workspace",
    "watch": "ng build --watch --configuration development",
    "publish:package": "npm publish --workspace",
    "clean": "npm run clean --workspaces --if-present && rm -rf packages/*/dist",
    "lint": "npm run lint --workspaces --if-present",
    "test:browser": "playwright test --project=chromium",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "test:browser:cross": "CI=1 playwright test --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:all": "CI=1 playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:ci": "CI=1 playwright test --project=chromium --workers=1",
    "test:browser:install": "playwright install chromium",
    "test:browser:install:all": "playwright install chromium firefox webkit",
    "version:packages": "npm version --workspaces",
    "dev": "concurrently \"npm run start:https\" \"npm run dev:packages\"",
    "dev:packages": "npm run build --workspaces --if-present -- --watch",
    "ssl:generate": "cd ssl && openssl genrsa -out localhost.key 2048 && openssl req -new -x509 -key localhost.key -out localhost.crt -days 365 -config localhost.conf"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.0",
    "ng-packagr": "^21.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
