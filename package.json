{
  "name": "angular-helpers",
  "version": "1.41.1",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "start:test": "ng serve --configuration development --host 127.0.0.1 --port 4200 --ssl=false",
    "build": "pnpm build:workers && ng build",
    "build:workers": "vite build",
    "build:gh-pages": "ng build --base-href /angular-helpers/",
    "build:gh-pages-root": "ng build --base-href /",
    "build:packages": "pnpm -r build",
    "build:packages:prod": "pnpm -r build:prod",
    "build:package": "pnpm build --filter",
    "build:schematics": "pnpm --filter @angular-helpers/schematics build",
    "generate:package": "ng generate ./dist/packages/schematics/collection.json:create-package",
    "watch": "ng build --watch --configuration development",
    "publish:package": "pnpm publish --filter",
    "clean": "node scripts/clean.js",
    "lint": "oxlint . && eslint .",
    "lint:ts": "oxlint .",
    "lint:angular": "eslint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "generate:docs": "node scripts/task-runner.js generate:docs",
    "test:docs-consistency": "node scripts/task-runner.js test:docs-consistency",
    "test:browser": "node scripts/task-runner.js test:browser",
    "test:browser:headed": "node scripts/task-runner.js test:browser headed",
    "test:browser:debug": "node scripts/task-runner.js test:browser debug",
    "test:browser:cross": "node scripts/task-runner.js test:browser cross",
    "test:browser:all": "node scripts/task-runner.js test:browser all",
    "test:browser:ci": "node scripts/task-runner.js test:browser ci",
    "test:browser:smoke": "node scripts/task-runner.js test:browser smoke",
    "test:browser:install": "node scripts/task-runner.js test:browser install",
    "test:browser:install:all": "node scripts/task-runner.js test:browser install:all",
    "test": "vitest run && vitest run -c test/vitest.schematics.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "version:packages": "pnpm -r version",
    "dev": "concurrently \"pnpm start:https\" \"pnpm dev:packages\"",
    "dev:packages": "pnpm -r --parallel dev",
    "ssl:generate": "node scripts/task-runner.js ssl:generate",
    "prepare": "husky",
    "serve:ssr:angular-helpers": "node dist/angular-helpers/server/server.mjs"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js,json,css,html,md}": "oxfmt",
    "*.{ts,js}": "oxlint",
    "*.{ts,html}": "eslint"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@angular/animations": "catalog:",
    "@angular/common": "catalog:",
    "@angular/compiler": "catalog:",
    "@angular/core": "catalog:",
    "@angular/forms": "catalog:",
    "@angular/platform-browser": "catalog:",
    "@angular/platform-server": "catalog:",
    "@angular/router": "catalog:",
    "@angular/ssr": "catalog:",
    "@toon-format/toon": "catalog:",
    "express": "catalog:",
    "highlight.js": "catalog:",
    "marked": "catalog:",
    "rxjs": "catalog:",
    "seroval": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "catalog:",
    "@analogjs/vitest-angular": "catalog:",
    "@angular-devkit/build-angular": "catalog:",
    "@angular-devkit/core": "catalog:",
    "@angular-devkit/schematics": "catalog:",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "catalog:",
    "@angular/platform-browser-dynamic": "catalog:",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "angular-eslint": "^22.0.0",
    "concurrently": "^9.2.3",
    "daisyui": "^5.5.23",
    "esbuild": "catalog:",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^1.70.0",
    "husky": "^9.1.7",
    "jsdom": "catalog:",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^22.0.0",
    "ol": "catalog:",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "semantic-release": "^25.0.5",
    "semantic-release-monorepo": "^8.0.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:",
    "web-streams-polyfill": "catalog:"
  }
}
