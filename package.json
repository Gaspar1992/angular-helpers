{
  "name": "angular-helpers",
  "version": "1.41.1",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "start:test": "ng serve --configuration development --host 127.0.0.1 --port 4200 --ssl=false",
    "build": "ng build",
    "build:workers": "vite build",
    "build:gh-pages": "ng build --base-href /angular-helpers/",
    "build:gh-pages-root": "ng build --base-href /",
    "build:packages": "pnpm -r build",
    "build:packages:prod": "pnpm -r build:prod",
    "build:package": "pnpm build --filter",
    "watch": "ng build --watch --configuration development",
    "publish:package": "pnpm publish --filter",
    "clean": "pnpm -r clean && rm -rf packages/*/dist",
    "lint": "oxlint . && eslint .",
    "lint:ts": "oxlint .",
    "lint:angular": "eslint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "generate:docs": "node scripts/task-runner.js generate:docs",
    "test:docs-consistency": "node scripts/task-runner.js test:docs-consistency",
    "test:browser": "node scripts/task-runner.js test:browser",
    "test:browser:headed": "node scripts/task-runner.js test:browser headed",
    "test:browser:debug": "node scripts/task-runner.js test:browser debug",
    "test:browser:cross": "node scripts/task-runner.js test:browser cross",
    "test:browser:all": "node scripts/task-runner.js test:browser all",
    "test:browser:ci": "node scripts/task-runner.js test:browser ci",
    "test:browser:smoke": "node scripts/task-runner.js test:browser smoke",
    "test:browser:install": "node scripts/task-runner.js test:browser install",
    "test:browser:install:all": "node scripts/task-runner.js test:browser install:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "version:packages": "pnpm -r version",
    "dev": "concurrently \"pnpm start:https\" \"pnpm dev:packages\"",
    "dev:packages": "pnpm -r --parallel dev",
    "ssl:generate": "node scripts/task-runner.js ssl:generate",
    "prepare": "husky",
    "serve:ssr:angular-helpers": "node dist/angular-helpers/server/server.mjs"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js,json,css,html,md}": "oxfmt",
    "*.{ts,js}": "oxlint",
    "*.{ts,html}": "eslint"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@toon-format/toon": "^2.2.0",
    "express": "^5.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "rxjs": "~7.8.0",
    "seroval": "^1.5.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular-devkit/build-angular": "^22.0.0",
    "angular-eslint": "^22.0.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.1.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.28.1",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "^1.67.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "milsymbol": "^3.0.4",
    "ng-packagr": "^22.0.0",
    "ol": "^10.9.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "web-streams-polyfill": "^4.2.0"
  }
}
