{
  "name": "angular-helpers",
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "start:test": "ng serve --configuration development --host 127.0.0.1 --port 4200 --ssl=false",
    "build": "ng build",
    "build:packages": "npm run build --workspaces --if-present",
    "build:packages:prod": "npm run build:prod --workspaces --if-present",
    "build:package": "npm run build --workspace",
    "watch": "ng build --watch --configuration development",
    "publish:package": "npm publish --workspace",
    "clean": "npm run clean --workspaces --if-present && rm -rf packages/*/dist",
    "lint": "npm run lint --workspaces --if-present",
    "test:browser": "CI=1 playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "test:browser:cross": "CI=1 playwright test --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:all": "CI=1 playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:ci": "CI=1 playwright test --project=chromium --workers=1",
    "test:browser:install": "playwright install chromium",
    "test:browser:install:all": "playwright install chromium firefox webkit",
    "version:packages": "npm version --workspaces",
    "dev": "concurrently \"npm run start:https\" \"npm run dev:packages\"",
    "dev:packages": "npm run build --workspaces --if-present -- --watch",
    "ssl:generate": "mkdir -p ssl && openssl req -x509 -newkey rsa:2048 -sha256 -nodes -keyout ssl/localhost.key -out ssl/localhost.crt -days 365 -subj '/CN=localhost' -addext 'subjectAltName=DNS:localhost,IP:127.0.0.1'"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "ng-packagr": "^21.0.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.2"
  }
}
