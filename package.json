{
  "name": "angular-helpers",
  "version": "1.41.1",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "start:test": "ng serve --configuration development --host 127.0.0.1 --port 4200 --ssl=false",
    "build": "ng build",
    "build:workers": "vite build",
    "build:gh-pages": "ng build --base-href /angular-helpers/",
    "build:gh-pages-root": "ng build --base-href /",
    "build:packages": "pnpm -r build",
    "build:packages:prod": "pnpm -r build:prod",
    "build:package": "pnpm build --filter",
    "watch": "ng build --watch --configuration development",
    "publish:package": "pnpm publish --filter",
    "clean": "pnpm -r clean && rm -rf packages/*/dist",
    "lint": "oxlint . && eslint .",
    "lint:ts": "oxlint .",
    "lint:angular": "eslint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test:docs-consistency": "npx tsx scripts/verify-docs-consistency.ts",
    "test:browser": "CI=1 playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:headed": "playwright test --headed",
    "test:browser:debug": "playwright test --debug",
    "test:browser:cross": "CI=1 playwright test --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:all": "CI=1 playwright test --project=chromium --project=firefox-smoke --project=webkit-smoke --workers=1",
    "test:browser:ci": "CI=1 playwright test --project=chromium --workers=1",
    "test:browser:smoke": "playwright test smoke.spec.ts --project=chromium",
    "test:browser:install": "playwright install chromium",
    "test:browser:install:all": "playwright install chromium firefox webkit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "version:packages": "pnpm -r version",
    "dev": "concurrently \"pnpm start:https\" \"pnpm dev:packages\"",
    "dev:packages": "pnpm -r --parallel dev",
    "ssl:generate": "mkdir -p ssl && openssl req -x509 -newkey rsa:2048 -sha256 -nodes -keyout ssl/localhost.key -out ssl/localhost.crt -days 365 -subj '/CN=localhost' -addext 'subjectAltName=DNS:localhost,IP:127.0.0.1'",
    "prepare": "husky"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js,json,css,html,md}": "oxfmt",
    "*.{ts,js}": "oxlint",
    "*.{ts,html}": "eslint"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "overrides": {
      "@angular/core": "^21.2.0",
      "@angular/common": "^21.2.0",
      "@angular/compiler": "^21.2.0",
      "@angular/forms": "^21.2.0",
      "@angular/platform-browser": "^21.2.0",
      "@angular/router": "^21.2.0"
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.3",
    "@toon-format/toon": "^2.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "rxjs": "~7.8.0",
    "seroval": "^1.5.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.1.0",
    "daisyui": "^5.5.19",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.1",
    "eslint-plugin-oxlint": "^1.61.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "milsymbol": "^3.0.4",
    "ng-packagr": "^21.2.3",
    "ol": "^10.9.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "web-streams-polyfill": "^4.2.0"
  }
}
