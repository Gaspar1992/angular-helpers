{
  "name": "angular-helpers",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https": "ng serve --ssl",
    "build": "ng build",
    "build:packages": "npm run build --workspaces --if-present",
    "build:package": "npm run build --workspace",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:packages": "npm test --workspaces --if-present",
    "publish:package": "npm publish --workspace",
    "clean": "npm run clean --workspaces --if-present && rm -rf packages/*/dist",
    "lint": "npm run lint --workspaces --if-present",
    "version:packages": "npm version --workspaces",
    "dev": "concurrently \"npm run start:https\" \"npm run dev:packages\"",
    "dev:packages": "npm run build --workspaces --if-present -- --watch",
    "ssl:generate": "cd ssl && openssl genrsa -out localhost.key 2048 && openssl req -new -x509 -key localhost.key -out localhost.crt -days 365 -config localhost.conf"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.1.0",
    "jasmine-core": "~5.1.0",
    "jsdom": "^28.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
